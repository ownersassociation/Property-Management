# =============================================================================
# Property Management Portal - Environment Configuration
# =============================================================================

# Database (Neon PostgreSQL)
# POOLED connection for app runtime (PgBouncer handles connection pooling)
DATABASE_URL="postgresql://username:password@ep-xxx-pooler.us-east-1.aws.neon.tech/dbname?sslmode=require"

# DIRECT (unpooled) connection for Prisma migrations and seed scripts
# This is the same URL but WITHOUT "-pooler" in the hostname
DIRECT_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require"

# Session Secret (generate strong random string, min 32 chars)
SESSION_SECRET="change-this-to-a-64-character-random-string-in-production"

# Cloudinary (for receipt/document storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App Settings
PORT=3000
NODE_ENV=production
APP_URL=https://your-app.vercel.app

# Admin Setup (comma-separated emails for initial admin accounts)
ADMIN_EMAILS=admin@example.com

# Accountant Setup (comma-separated emails for initial accountant accounts)
ACCOUNTANT_EMAILS=accountant@example.com
