# Copy this file to .env and replace the placeholder values.
# Steps:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update the values below with your local configuration.
# 3. Restart the app after changing the environment variables.

# Server
NODE_ENV=development
PORT=3000

# Database
# Example PostgreSQL URL: postgresql://username:password@localhost:5432/property_management
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property_management

# Session security
# Use a long random string in production.
SESSION_SECRET=change-this-secret-in-production

# User role auto-assignment
# Comma-separated email addresses that should receive admin or accountant access.
ADMIN_EMAILS=admin@example.com
ACCOUNTANT_EMAILS=accountant@example.com

# Cloudinary (for file uploads)
# Create an account at https://cloudinary.com/ and get these values from your dashboard.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
