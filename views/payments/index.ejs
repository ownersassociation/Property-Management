<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-credit-card me-2 text-primary"></i>Payments & Dues</h2>
</div>

<!-- Summary Cards -->
<% if (summary) { %>
<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Total Billed</h6>
        <h3 class="fw-bold text-primary">&#8377;<%= Math.round(summary.totalBilled).toLocaleString('en-IN') %></h3>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Total Paid</h6>
        <h3 class="fw-bold text-success">&#8377;<%= Math.round(summary.totalPaid).toLocaleString('en-IN') %></h3>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Balance Due</h6>
        <h3 class="fw-bold text-danger">&#8377;<%= Math.round(summary.totalDue).toLocaleString('en-IN') %></h3>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Overdue</h6>
        <h3 class="fw-bold text-warning"><%= summary.overdueCount %></h3>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Filters & Add Payment -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div class="row g-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Status</label>
        <select class="form-select" onchange="location.href='?status='+this.value<%= selectedUnit ? "+ '&unitId=' + selectedUnit" : '' %>">
          <option value="">All Status</option>
          <option value="due" <%= selectedStatus === 'due' ? 'selected' : '' %>>Due</option>
          <option value="paid" <%= selectedStatus === 'paid' ? 'selected' : '' %>>Paid</option>
          <option value="overdue" <%= selectedStatus === 'overdue' ? 'selected' : '' %>>Overdue</option>
          <option value="partial" <%= selectedStatus === 'partial' ? 'selected' : '' %>>Partial</option>
        </select>
      </div>
      <% if (isAdmin || isAccountant) { %>
        <div class="col-md-3">
          <label class="form-label">Unit</label>
          <select class="form-select" onchange="location.href='?unitId='+this.value<%= selectedStatus ? "+ '&status=' + selectedStatus" : '' %>">
            <option value="">All Units</option>
            <% units.forEach(u => { %>
              <option value="<%= u.id %>" <%= selectedUnit === u.id ? 'selected' : '' %>><%= u.building %> - <%= u.unitNumber %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6 text-end">
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPaymentModal">
            <i class="bi bi-plus-lg me-2"></i>Record Payment
          </button>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Payments Table -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Unit</th>
            <th>Description</th>
            <th class="text-end">Amount</th>
            <th class="text-end">Paid</th>
            <th class="text-end">Balance</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Receipt</th>
            <% if (isAccountant || isAdmin) { %><th>Actions</th><% } %>
          </tr>
        </thead>
        <tbody>
          <% if (payments && payments.length > 0) { %>
            <% payments.forEach(p => { %>
              <tr>
                <td><span class="fw-semibold"><%= p.unit.building %> - <%= p.unit.unitNumber %></span></td>
                <td><%= p.description %></td>
                <td class="text-end">&#8377;<%= Number(p.amount).toLocaleString('en-IN') %></td>
                <td class="text-end">&#8377;<%= Number(p.paidAmount).toLocaleString('en-IN') %></td>
                <td class="text-end fw-bold <%= p.balance > 0 ? 'text-danger' : 'text-success' %>">&#8377;<%= Number(p.balance).toLocaleString('en-IN') %></td>
                <td><%= moment(p.dueDate).format('DD MMM YYYY') %></td>
                <td>
                  <span class="badge bg-<%= p.status === 'paid' ? 'success' : p.status === 'overdue' ? 'danger' : p.status === 'partial' ? 'warning text-dark' : 'secondary' %>">
                    <%= p.status %>
                  </span>
                </td>
                <td>
                  <% if (p.receiptUrl) { %>
                    <a href="<%= p.receiptUrl %>" target="_blank" class="btn btn-sm btn-outline-success"><i class="bi bi-file-earmark-text"></i></a>
                  <% } else { %>-<% } %>
                </td>
                <% if (isAccountant || isAdmin) { %>
                  <td>
                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editPaymentModal<%= p.id %>">
                      <i class="bi bi-pencil"></i>
                    </button>
                  </td>
                <% } %>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="<%= isAccountant || isAdmin ? 9 : 8 %>" class="text-center py-4 text-muted">No payments found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Payment Modal -->
<% if (isAdmin || isAccountant) { %>
<div class="modal fade" id="addPaymentModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Record New Payment</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/payments/record" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Unit <span class="text-danger">*</span></label>
              <select class="form-select" name="unitId" required>
                <option value="">Select Unit</option>
                <% units.forEach(u => { %>
                  <option value="<%= u.id %>"><%= u.building %> - <%= u.unitNumber %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Due Date <span class="text-danger">*</span></label>
              <input type="date" class="form-control" name="dueDate" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Description <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="description" placeholder="e.g., Monthly Maintenance" required>
          </div>
          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label">Amount (&#8377;) <span class="text-danger">*</span></label>
              <input type="number" class="form-control" name="amount" step="0.01" required>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Paid Amount (&#8377;)</label>
              <input type="number" class="form-control" name="paidAmount" step="0.01" value="0">
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Status</label>
              <select class="form-select" name="status">
                <option value="due">Due</option>
                <option value="paid">Paid</option>
                <option value="partial">Partial</option>
                <option value="overdue">Overdue</option>
              </select>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Receipt</label>
            <input type="file" class="form-control" name="receipt" accept="image/*,.pdf">
          </div>
          <div class="mb-3">
            <label class="form-label">Notes</label>
            <textarea class="form-control" name="notes" rows="2"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Record Payment</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>
