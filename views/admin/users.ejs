<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-people me-2 text-primary"></i>User Management</h2>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap gap-2">
      <a href="/admin/users" class="btn btn-sm <%= !selectedRole ? 'btn-primary' : 'btn-outline-secondary' %>">All</a>
      <a href="/admin/users?role=admin" class="btn btn-sm <%= selectedRole === 'admin' ? 'btn-primary' : 'btn-outline-secondary' %>">Admin</a>
      <a href="/admin/users?role=accountant" class="btn btn-sm <%= selectedRole === 'accountant' ? 'btn-primary' : 'btn-outline-secondary' %>">Accountant</a>
      <a href="/admin/users?role=owner" class="btn btn-sm <%= selectedRole === 'owner' ? 'btn-primary' : 'btn-outline-secondary' %>">Owner</a>
      <a href="/admin/users?role=resident" class="btn btn-sm <%= selectedRole === 'resident' ? 'btn-primary' : 'btn-outline-secondary' %>">Resident</a>
      <a href="/admin/users?role=pending" class="btn btn-sm <%= selectedRole === 'pending' ? 'btn-primary' : 'btn-outline-secondary' %>">Pending</a>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Units</th><th>Joined</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% if (users && users.length > 0) { %>
            <% users.forEach(u => { %>
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 36px; height: 36px;">
                      <i class="bi bi-person small"></i>
                    </div>
                    <span class="fw-semibold"><%= u.firstName %> <%= u.lastName %></span>
                  </div>
                </td>
                <td><%= u.email %></td>
                <td>
                  <span class="badge bg-<%= u.role === 'admin' ? 'danger' : u.role === 'accountant' ? 'warning text-dark' : u.role === 'owner' ? 'success' : u.role === 'pending' ? 'secondary' : 'info' %>">
                    <%= u.role %>
                  </span>
                </td>
                <td>
                  <span class="badge bg-<%= u.status === 'active' ? 'success' : 'secondary' %>"><%= u.status %></span>
                </td>
                <td>
                  <small class="text-muted">
                    Owner: <%= u.ownedUnits.length %> | Resident: <%= u.residentUnits.length %>
                  </small>
                </td>
                <td><small><%= moment(u.createdAt).format('DD MMM YYYY') %></small></td>
                <td>
                  <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editUserModal<%= u.id %>">
                    <i class="bi bi-pencil"></i>
                  </button>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="7" class="text-center py-4 text-muted">No users found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Edit User Modals -->
<% users.forEach(u => { %>
<div class="modal fade" id="editUserModal<%= u.id %>" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit User: <%= u.firstName %> <%= u.lastName %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/users/<%= u.id %>" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Role</label>
            <select class="form-select" name="role">
              <option value="pending" <%= u.role === 'pending' ? 'selected' : '' %>>Pending</option>
              <option value="resident" <%= u.role === 'resident' ? 'selected' : '' %>>Resident</option>
              <option value="owner" <%= u.role === 'owner' ? 'selected' : '' %>>Owner</option>
              <option value="accountant" <%= u.role === 'accountant' ? 'selected' : '' %>>Accountant</option>
              <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Status</label>
            <select class="form-select" name="status">
              <option value="active" <%= u.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= u.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
              <option value="suspended" <%= u.status === 'suspended' ? 'selected' : '' %>>Suspended</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Assign Unit</label>
            <select class="form-select" name="unitId">
              <option value="">Select Unit</option>
              <% units.forEach(unit => { %>
                <option value="<%= unit.id %>"><%= unit.building %> - <%= unit.unitNumber %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Unit Role</label>
            <select class="form-select" name="unitRole">
              <option value="owner">Owner</option>
              <option value="resident">Resident</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% }) %>
