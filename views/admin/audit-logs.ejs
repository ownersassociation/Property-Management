<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-journal-text me-2 text-primary"></i>Audit Logs</h2>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" class="row g-3">
      <div class="col-md-4">
        <label class="form-label">Entity</label>
        <select class="form-select" name="entity" onchange="this.form.submit()">
          <option value="">All Entities</option>
          <option value="LedgerEntry" <%= selectedEntity === 'LedgerEntry' ? 'selected' : '' %>>Ledger Entry</option>
          <option value="Payment" <%= selectedEntity === 'Payment' ? 'selected' : '' %>>Payment</option>
          <option value="Notice" <%= selectedEntity === 'Notice' ? 'selected' : '' %>>Notice</option>
          <option value="User" <%= selectedEntity === 'User' ? 'selected' : '' %>>User</option>
          <option value="Unit" <%= selectedEntity === 'Unit' ? 'selected' : '' %>>Unit</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">User</label>
        <select class="form-select" name="userId" onchange="this.form.submit()">
          <option value="">All Users</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>" <%= selectedUser === u.id ? 'selected' : '' %>><%= u.firstName %> <%= u.lastName %></option>
          <% }) %>
        </select>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr><th>Time</th><th>User</th><th>Action</th><th>Entity</th><th>Entity ID</th><th>Details</th></tr>
        </thead>
        <tbody>
          <% if (logs && logs.length > 0) { %>
            <% logs.forEach(log => { %>
              <tr>
                <td><small><%= moment(log.createdAt).format('DD MMM YYYY HH:mm:ss') %></small></td>
                <td><%= log.user.firstName %> <%= log.user.lastName %></td>
                <td>
                  <span class="badge bg-<%= log.action === 'CREATE' ? 'success' : log.action === 'UPDATE' ? 'warning text-dark' : log.action === 'DELETE' ? 'danger' : 'info' %>">
                    <%= log.action %>
                  </span>
                </td>
                <td><%= log.entity %></td>
                <td><small class="font-monospace"><%= log.entityId || '-' %></small></td>
                <td><small class="text-muted text-truncate d-inline-block" style="max-width: 400px;"><%= log.details %></small></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="6" class="text-center py-4 text-muted">No audit logs found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (totalPages > 1) { %>
    <div class="card-footer bg-white">
      <nav><ul class="pagination justify-content-center mb-0">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= currentPage == i ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= i %><%= selectedEntity ? '&entity=' + selectedEntity : '' %><%= selectedUser ? '&userId=' + selectedUser : '' %>"><%= i %></a>
          </li>
        <% } %>
      </ul></nav>
    </div>
  <% } %>
</div>
