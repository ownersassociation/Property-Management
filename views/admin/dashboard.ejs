<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-shield-lock me-2 text-primary"></i>Admin Dashboard</h2>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <div class="stat-icon bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 60px; height: 60px;">
          <i class="bi bi-people fs-3"></i>
        </div>
        <h3 class="fw-bold mb-0"><%= stats.totalUsers %></h3>
        <p class="text-muted mb-0">Total Users</p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <div class="stat-icon bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 60px; height: 60px;">
          <i class="bi bi-building fs-3"></i>
        </div>
        <h3 class="fw-bold mb-0"><%= stats.totalUnits %></h3>
        <p class="text-muted mb-0">Total Units</p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <div class="stat-icon bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 60px; height: 60px;">
          <i class="bi bi-hourglass-split fs-3"></i>
        </div>
        <h3 class="fw-bold mb-0"><%= stats.pendingUsers %></h3>
        <p class="text-muted mb-0">Pending Users</p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <div class="stat-icon bg-info bg-opacity-10 text-info rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 60px; height: 60px;">
          <i class="bi bi-receipt fs-3"></i>
        </div>
        <h3 class="fw-bold mb-0"><%= stats.totalLedgerEntries %></h3>
        <p class="text-muted mb-0">Ledger Entries</p>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Total Billed</h6>
        <h4 class="fw-bold text-primary">&#8377;<%= Math.round(stats.totalBilled).toLocaleString('en-IN') %></h4>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Total Paid</h6>
        <h4 class="fw-bold text-success">&#8377;<%= Math.round(stats.totalPaid).toLocaleString('en-IN') %></h4>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Total Expenses</h6>
        <h4 class="fw-bold text-danger">&#8377;<%= Math.round(stats.totalExpenses).toLocaleString('en-IN') %></h4>
      </div>
    </div>
  </div>
</div>

<!-- Quick Links -->
<div class="row g-4 mb-4">
  <div class="col-md-3">
    <a href="/admin/users" class="card border-0 shadow-sm text-decoration-none h-100">
      <div class="card-body text-center">
        <i class="bi bi-people fs-1 text-primary mb-2"></i>
        <h5 class="text-dark">Users</h5>
        <p class="text-muted small mb-0">Manage users & roles</p>
      </div>
    </a>
  </div>
  <div class="col-md-3">
    <a href="/admin/units" class="card border-0 shadow-sm text-decoration-none h-100">
      <div class="card-body text-center">
        <i class="bi bi-building fs-1 text-success mb-2"></i>
        <h5 class="text-dark">Units</h5>
        <p class="text-muted small mb-0">Manage property units</p>
      </div>
    </a>
  </div>
  <div class="col-md-3">
    <a href="/admin/audit-logs" class="card border-0 shadow-sm text-decoration-none h-100">
      <div class="card-body text-center">
        <i class="bi bi-journal-text fs-1 text-warning mb-2"></i>
        <h5 class="text-dark">Audit Logs</h5>
        <p class="text-muted small mb-0">View activity logs</p>
      </div>
    </a>
  </div>
  <div class="col-md-3">
    <a href="/expenses" class="card border-0 shadow-sm text-decoration-none h-100">
      <div class="card-body text-center">
        <i class="bi bi-graph-up fs-1 text-info mb-2"></i>
        <h5 class="text-dark">Expenses</h5>
        <p class="text-muted small mb-0">View expense reports</p>
      </div>
    </a>
  </div>
</div>

<!-- Recent Audit Logs -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
    <h5 class="mb-0 fw-semibold"><i class="bi bi-journal-text me-2 text-primary"></i>Recent Activity</h5>
    <a href="/admin/audit-logs" class="btn btn-sm btn-outline-primary">View All</a>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr><th>Time</th><th>User</th><th>Action</th><th>Entity</th><th>Details</th></tr>
        </thead>
        <tbody>
          <% if (recentAuditLogs && recentAuditLogs.length > 0) { %>
            <% recentAuditLogs.forEach(log => { %>
              <tr>
                <td><small><%= moment(log.createdAt).format('DD MMM HH:mm') %></small></td>
                <td><%= log.user.firstName %> <%= log.user.lastName %></td>
                <td><span class="badge bg-<%= log.action === 'CREATE' ? 'success' : log.action === 'UPDATE' ? 'warning text-dark' : log.action === 'DELETE' ? 'danger' : 'info' %>"><%= log.action %></span></td>
                <td><%= log.entity %></td>
                <td><small class="text-muted text-truncate d-inline-block" style="max-width: 300px;"><%= log.details %></small></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="5" class="text-center py-4 text-muted">No activity logs</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
