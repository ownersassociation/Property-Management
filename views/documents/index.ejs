<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-folder me-2 text-primary"></i>Document Vault</h2>
</div>

<!-- Upload Form -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white py-3"><h5 class="mb-0 fw-semibold"><i class="bi bi-upload me-2"></i>Upload Document</h5></div>
  <div class="card-body">
    <form action="/documents" method="POST" enctype="multipart/form-data">
      <div class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label">Unit <span class="text-danger">*</span></label>
          <select class="form-select" name="unitId" required>
            <option value="">Select Unit</option>
            <% units.forEach(u => { %>
              <option value="<%= u.id %>"><%= u.building %> - <%= u.unitNumber %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Title <span class="text-danger">*</span></label>
          <input type="text" class="form-control" name="title" placeholder="Document title" required>
        </div>
        <div class="col-md-2">
          <label class="form-label">Category</label>
          <select class="form-select" name="category">
            <option value="agreement">Agreement</option>
            <option value="noc">NOC</option>
            <option value="correspondence">Correspondence</option>
            <option value="receipt">Receipt</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">File <span class="text-danger">*</span></label>
          <input type="file" class="form-control" name="file" required>
        </div>
        <div class="col-md-1">
          <button type="submit" class="btn btn-primary w-100"><i class="bi bi-upload"></i></button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Documents List -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Unit</th>
            <th>Title</th>
            <th>Category</th>
            <th>Uploaded By</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (documents && documents.length > 0) { %>
            <% documents.forEach(doc => { %>
              <tr>
                <td><span class="fw-semibold"><%= doc.unit.building %> - <%= doc.unit.unitNumber %></span></td>
                <td><%= doc.title %></td>
                <td><span class="badge bg-light text-dark border"><%= doc.category %></span></td>
                <td><%= doc.uploader.firstName %> <%= doc.uploader.lastName %></td>
                <td><%= moment(doc.createdAt).format('DD MMM YYYY') %></td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <a href="<%= doc.fileUrl %>" target="_blank" class="btn btn-outline-primary"><i class="bi bi-eye"></i></a>
                    <form action="/documents/<%= doc.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this document?');">
                      <button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="6" class="text-center py-4 text-muted">No documents found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
