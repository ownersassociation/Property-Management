<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold"><i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard</h2>
  <span class="text-muted"><%= moment().format('dddd, MMMM D, YYYY') %></span>
</div>

<!-- Welcome Card -->
<div class="card border-0 shadow-sm mb-4 bg-gradient-primary text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
  <div class="card-body p-4">
    <div class="d-flex align-items-center">
      <div class="flex-grow-1">
        <h4 class="mb-1">Welcome back, <%= user.firstName %>!</h4>
        <p class="mb-0 opacity-75">Here's what's happening in your society today.</p>
      </div>
      <i class="bi bi-building fs-1 opacity-50"></i>
    </div>
  </div>
</div>

<!-- Stats Row -->
<div class="row g-4 mb-4">
  <% if (expenseSummary) { %>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0">
            <div class="stat-icon bg-danger bg-opacity-10 text-danger rounded-3 p-3">
              <i class="bi bi-currency-rupee fs-4"></i>
            </div>
          </div>
          <div class="flex-grow-1 ms-3">
            <h6 class="text-muted mb-1">Total Expenses</h6>
            <h4 class="mb-0 fw-bold">&#8377;<%= expenseSummary.total.toLocaleString('en-IN') %></h4>
            <small class="text-muted"><%= expenseSummary.count %> entries</small>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <% if (paymentSummary) { %>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0">
            <div class="stat-icon bg-success bg-opacity-10 text-success rounded-3 p-3">
              <i class="bi bi-wallet2 fs-4"></i>
            </div>
          </div>
          <div class="flex-grow-1 ms-3">
            <h6 class="text-muted mb-1">Total Paid</h6>
            <h4 class="mb-0 fw-bold">&#8377;<%= paymentSummary.totalPaid.toLocaleString('en-IN') %></h4>
            <small class="text-muted">of &#8377;<%= paymentSummary.totalBilled.toLocaleString('en-IN') %></small>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0">
            <div class="stat-icon bg-warning bg-opacity-10 text-warning rounded-3 p-3">
              <i class="bi bi-exclamation-circle fs-4"></i>
            </div>
          </div>
          <div class="flex-grow-1 ms-3">
            <h6 class="text-muted mb-1">Amount Due</h6>
            <h4 class="mb-0 fw-bold text-danger">&#8377;<%= paymentSummary.totalDue.toLocaleString('en-IN') %></h4>
            <small class="text-muted"><%= paymentSummary.overdueCount %> overdue</small>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0">
            <div class="stat-icon bg-info bg-opacity-10 text-info rounded-3 p-3">
              <i class="bi bi-bell fs-4"></i>
            </div>
          </div>
          <div class="flex-grow-1 ms-3">
            <h6 class="text-muted mb-1">Unread Notices</h6>
            <h4 class="mb-0 fw-bold"><%= unreadCount %></h4>
            <small class="text-muted">new announcements</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <!-- Notices Column -->
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 fw-semibold"><i class="bi bi-megaphone me-2 text-primary"></i>Recent Notices</h5>
        <a href="/notices" class="btn btn-sm btn-outline-primary">View All</a>
      </div>
      <div class="card-body p-0">
        <div class="list-group list-group-flush">
          <% if (notices && notices.length > 0) { %>
            <% notices.forEach(notice => { %>
              <a href="/notices/<%= notice.id %>" class="list-group-item list-group-item-action d-flex gap-3 py-3 <%= notice.isRead ? '' : 'bg-light' %>">
                <div class="flex-shrink-0">
                  <% if (notice.category === 'emergency') { %>
                    <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i></span>
                  <% } else if (notice.category === 'billing') { %>
                    <span class="badge bg-success"><i class="bi bi-currency-rupee"></i></span>
                  <% } else if (notice.category === 'maintenance') { %>
                    <span class="badge bg-warning text-dark"><i class="bi bi-tools"></i></span>
                  <% } else if (notice.category === 'event') { %>
                    <span class="badge bg-info"><i class="bi bi-calendar-event"></i></span>
                  <% } else { %>
                    <span class="badge bg-secondary"><i class="bi bi-info-circle"></i></span>
                  <% } %>
                </div>
                <div class="flex-grow-1">
                  <div class="d-flex w-100 justify-content-between">
                    <h6 class="mb-1 <%= notice.isRead ? '' : 'fw-bold' %>"><%= notice.title %></h6>
                    <small class="text-muted"><%= moment(notice.createdAt).fromNow() %></small>
                  </div>
                  <p class="mb-1 text-muted small text-truncate"><%= notice.body %></p>
                  <% if (!notice.isRead) { %>
                    <span class="badge bg-primary bg-opacity-10 text-primary">New</span>
                  <% } %>
                </div>
              </a>
            <% }) %>
          <% } else { %>
            <div class="text-center py-4 text-muted">
              <i class="bi bi-inbox fs-1"></i>
              <p class="mb-0">No notices available</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Upcoming Events Column -->
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 fw-semibold"><i class="bi bi-calendar3 me-2 text-primary"></i>Upcoming Events</h5>
        <a href="/schedule" class="btn btn-sm btn-outline-primary">View Calendar</a>
      </div>
      <div class="card-body p-0">
        <div class="list-group list-group-flush">
          <% if (upcomingSchedules && upcomingSchedules.length > 0) { %>
            <% upcomingSchedules.forEach(event => { %>
              <div class="list-group-item d-flex gap-3 py-3">
                <div class="flex-shrink-0 text-center" style="min-width: 60px;">
                  <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2">
                    <div class="fw-bold fs-5"><%= moment(event.startDate).format('DD') %></div>
                    <div class="small"><%= moment(event.startDate).format('MMM') %></div>
                  </div>
                </div>
                <div class="flex-grow-1">
                  <h6 class="mb-1"><%= event.title %></h6>
                  <p class="mb-1 text-muted small"><%= event.description || '' %></p>
                  <div class="d-flex gap-2">
                    <span class="badge bg-light text-dark"><i class="bi bi-clock me-1"></i><%= moment(event.startDate).format('h:mm A') %></span>
                    <% if (event.location) { %>
                      <span class="badge bg-light text-dark"><i class="bi bi-geo-alt me-1"></i><%= event.location %></span>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="text-center py-4 text-muted">
              <i class="bi bi-calendar-x fs-1"></i>
              <p class="mb-0">No upcoming events</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Active Projects -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 fw-semibold"><i class="bi bi-hammer me-2 text-primary"></i>Active Projects</h5>
        <a href="/projects" class="btn btn-sm btn-outline-primary">View All</a>
      </div>
      <div class="card-body">
        <% if (activeProjects && activeProjects.length > 0) { %>
          <% activeProjects.forEach(project => { %>
            <div class="mb-3">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="fw-semibold"><%= project.title %></span>
                <span class="badge bg-<%= project.status === 'in_progress' ? 'warning text-dark' : 'info' %>">
                  <%= project.status.replace('_', ' ') %>
                </span>
              </div>
              <% if (project.budget && project.actualCost) { %>
                <% const progress = Math.min((project.actualCost / project.budget) * 100, 100); %>
                <div class="progress" style="height: 8px;">
                  <div class="progress-bar bg-primary" style="width: <%= progress %>%"></div>
                </div>
                <div class="d-flex justify-content-between small text-muted mt-1">
                  <span>&#8377;<%= project.actualCost.toLocaleString('en-IN') %></span>
                  <span>&#8377;<%= project.budget.toLocaleString('en-IN') %></span>
                </div>
              <% } %>
            </div>
          <% }) %>
        <% } else { %>
          <div class="text-center py-3 text-muted">
            <i class="bi bi-clipboard-check fs-1"></i>
            <p class="mb-0">No active projects</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
