<div class="d-flex justify-content-between align-items-center mb-4">
  <a href="/notices" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-2"></i>Back to Notices
  </a>
  <% if (isAdmin) { %>
    <div class="btn-group">
      <a href="/notices/admin/<%= notice.id %>/edit" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
      <form action="/notices/<%= notice.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this notice?');">
        <button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
      </form>
    </div>
  <% } %>
</div>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <div class="d-flex gap-2 mb-3">
          <span class="badge bg-<%= notice.category === 'emergency' ? 'danger' : notice.category === 'billing' ? 'success' : notice.category === 'maintenance' ? 'warning text-dark' : notice.category === 'event' ? 'info' : 'secondary' %> fs-6">
            <%= notice.category %>
          </span>
          <% if (notice.isUrgent) { %>
            <span class="badge bg-danger fs-6"><i class="bi bi-exclamation-triangle me-1"></i>Urgent</span>
          <% } %>
        </div>

        <h2 class="fw-bold mb-3"><%= notice.title %></h2>

        <div class="d-flex align-items-center text-muted mb-4">
          <i class="bi bi-person-circle me-2"></i>
          <span><%= notice.author.firstName %> <%= notice.author.lastName %></span>
          <span class="mx-2">|</span>
          <i class="bi bi-clock me-2"></i>
          <span><%= moment(notice.createdAt).format('DD MMMM YYYY, h:mm A') %></span>
        </div>

        <% if (notice.attachmentUrl) { %>
          <div class="mb-4">
            <a href="<%= notice.attachmentUrl %>" target="_blank" class="btn btn-outline-primary">
              <i class="bi bi-paperclip me-2"></i>View Attachment
            </a>
          </div>
        <% } %>

        <div class="bg-light p-4 rounded-3">
          <p class="mb-0" style="white-space: pre-wrap;"><%= notice.body %></p>
        </div>

        <% if (notice.validUntil) { %>
          <div class="alert alert-info mt-4 mb-0">
            <i class="bi bi-calendar-check me-2"></i>Valid until <%= moment(notice.validUntil).format('DD MMMM YYYY') %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
