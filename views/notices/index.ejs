<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-megaphone me-2 text-primary"></i>Notices & Announcements</h2>
  <% if (isAdmin) { %>
    <a href="/notices/admin/new" class="btn btn-primary">
      <i class="bi bi-plus-lg me-2"></i>New Notice
    </a>
  <% } %>
</div>

<!-- Category Filter -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap gap-2">
      <a href="/notices" class="btn btn-sm <%= !selectedCategory ? 'btn-primary' : 'btn-outline-secondary' %>">All</a>
      <% categories.forEach(cat => { %>
        <a href="/notices?category=<%= cat %>" class="btn btn-sm <%= selectedCategory === cat ? 'btn-primary' : 'btn-outline-secondary' %>">
          <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
        </a>
      <% }) %>
    </div>
  </div>
</div>

<!-- Notices List -->
<div class="row g-4">
  <% if (notices && notices.length > 0) { %>
    <% notices.forEach(notice => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 <%= notice.isUrgent ? 'border-start border-danger border-4' : '' %>">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="badge bg-<%= notice.category === 'emergency' ? 'danger' : notice.category === 'billing' ? 'success' : notice.category === 'maintenance' ? 'warning text-dark' : notice.category === 'event' ? 'info' : 'secondary' %>">
                <%= notice.category %>
              </span>
              <% if (!notice.isRead) { %>
                <span class="badge bg-primary">New</span>
              <% } %>
            </div>
            <h5 class="card-title fw-semibold mb-2 <%= notice.isRead ? '' : 'text-primary' %>"><%= notice.title %></h5>
            <p class="card-text text-muted small text-truncate mb-3"><%= notice.body %></p>
            <div class="d-flex justify-content-between align-items-center">
              <small class="text-muted">
                <i class="bi bi-person me-1"></i><%= notice.author.firstName %> <%= notice.author.lastName %>
              </small>
              <small class="text-muted"><%= moment(notice.createdAt).fromNow() %></small>
            </div>
          </div>
          <div class="card-footer bg-white border-0 pt-0">
            <a href="/notices/<%= notice.id %>" class="btn btn-sm btn-outline-primary w-100">Read More</a>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="col-12 text-center py-5 text-muted">
      <i class="bi bi-inbox fs-1 d-block mb-3"></i>
      <p>No notices found</p>
    </div>
  <% } %>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
  <nav class="mt-4">
    <ul class="pagination justify-content-center">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage == i ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %><%= selectedCategory ? '&category=' + selectedCategory : '' %>"><%= i %></a>
        </li>
      <% } %>
    </ul>
  </nav>
<% } %>
