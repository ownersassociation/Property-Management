<div class="d-flex justify-content-between align-items-center mb-4">
  <a href="/projects" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Back</a>
  <% if (isAdmin) { %>
    <a href="/projects/admin/<%= project.id %>/edit" class="btn btn-outline-primary"><i class="bi bi-pencil me-2"></i>Edit</a>
  <% } %>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <% if (project.photos && project.photos.length > 0) { %>
        <div id="projectCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            <% project.photos.forEach((photo, i) => { %>
              <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                <img src="<%= photo %>" class="d-block w-100" style="height: 400px; object-fit: cover;" alt="Project photo">
              </div>
            <% }) %>
          </div>
          <% if (project.photos.length > 1) { %>
            <button class="carousel-control-prev" type="button" data-bs-target="#projectCarousel" data-bs-slide="prev">
              <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#projectCarousel" data-bs-slide="next">
              <span class="carousel-control-next-icon"></span>
            </button>
          <% } %>
        </div>
      <% } %>
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start mb-3">
          <div>
            <span class="badge bg-<%= project.status === 'in_progress' ? 'warning text-dark' : project.status === 'completed' ? 'success' : 'info' %> mb-2">
              <%= project.status.replace('_', ' ') %>
            </span>
            <h2 class="fw-bold"><%= project.title %></h2>
          </div>
        </div>
        <p class="text-muted" style="white-space: pre-wrap;"><%= project.description %></p>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white py-3"><h5 class="mb-0 fw-semibold">Project Details</h5></div>
      <div class="card-body">
        <div class="mb-3">
          <h6 class="text-muted mb-1">Start Date</h6>
          <p class="fw-semibold mb-0"><%= project.startDate ? moment(project.startDate).format('DD MMM YYYY') : 'Not set' %></p>
        </div>
        <div class="mb-3">
          <h6 class="text-muted mb-1">Target Completion</h6>
          <p class="fw-semibold mb-0"><%= project.targetDate ? moment(project.targetDate).format('DD MMM YYYY') : 'Not set' %></p>
        </div>
        <div class="mb-3">
          <h6 class="text-muted mb-1">Budget</h6>
          <p class="fw-semibold mb-0">&#8377;<%= project.budget ? Number(project.budget).toLocaleString('en-IN') : 'Not set' %></p>
        </div>
        <div class="mb-0">
          <h6 class="text-muted mb-1">Actual Cost</h6>
          <p class="fw-semibold mb-0">&#8377;<%= project.actualCost ? Number(project.actualCost).toLocaleString('en-IN') : '0' %></p>
        </div>
      </div>
    </div>
  </div>
</div>
