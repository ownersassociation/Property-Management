<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-hammer me-2 text-primary"></i>Ongoing Projects</h2>
  <% if (isAdmin) { %>
    <a href="/projects/admin/new" class="btn btn-primary"><i class="bi bi-plus-lg me-2"></i>New Project</a>
  <% } %>
</div>

<!-- Status Filter -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap gap-2">
      <a href="/projects" class="btn btn-sm <%= !selectedStatus ? 'btn-primary' : 'btn-outline-secondary' %>">All</a>
      <a href="/projects?status=planned" class="btn btn-sm <%= selectedStatus === 'planned' ? 'btn-primary' : 'btn-outline-secondary' %>">Planned</a>
      <a href="/projects?status=in_progress" class="btn btn-sm <%= selectedStatus === 'in_progress' ? 'btn-primary' : 'btn-outline-secondary' %>">In Progress</a>
      <a href="/projects?status=completed" class="btn btn-sm <%= selectedStatus === 'completed' ? 'btn-primary' : 'btn-outline-secondary' %>">Completed</a>
    </div>
  </div>
</div>

<div class="row g-4">
  <% if (projects && projects.length > 0) { %>
    <% projects.forEach(project => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
          <% if (project.photos && project.photos.length > 0) { %>
            <img src="<%= project.photos[0] %>" class="card-img-top" style="height: 180px; object-fit: cover;" alt="<%= project.title %>">
          <% } else { %>
            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
              <i class="bi bi-image text-muted fs-1"></i>
            </div>
          <% } %>
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="badge bg-<%= project.status === 'in_progress' ? 'warning text-dark' : project.status === 'completed' ? 'success' : project.status === 'on_hold' ? 'secondary' : 'info' %>">
                <%= project.status.replace('_', ' ') %>
              </span>
              <% if (project.budget && project.actualCost) { %>
                <% const pct = Math.round((project.actualCost / project.budget) * 100); %>
                <span class="badge bg-light text-dark border"><%= pct %>%</span>
              <% } %>
            </div>
            <h5 class="card-title fw-semibold"><%= project.title %></h5>
            <p class="card-text text-muted small text-truncate"><%= project.description %></p>

            <% if (project.budget) { %>
              <div class="mb-2">
                <div class="progress" style="height: 6px;">
                  <div class="progress-bar bg-primary" style="width: <%= Math.min((project.actualCost || 0) / project.budget * 100, 100) %>%"></div>
                </div>
              </div>
              <div class="d-flex justify-content-between small text-muted">
                <span>&#8377;<%= Number(project.actualCost || 0).toLocaleString('en-IN') %></span>
                <span>&#8377;<%= Number(project.budget).toLocaleString('en-IN') %></span>
              </div>
            <% } %>

            <div class="mt-3">
              <a href="/projects/<%= project.id %>" class="btn btn-sm btn-outline-primary w-100">View Details</a>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="col-12 text-center py-5 text-muted">
      <i class="bi bi-clipboard-check fs-1 d-block mb-3"></i>
      <p>No projects found</p>
    </div>
  <% } %>
</div>
