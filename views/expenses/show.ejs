<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-receipt me-2 text-primary"></i>Expense Details</h2>
  <a href="/expenses" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-2"></i>Back
  </a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white py-3">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <span class="badge bg-light text-dark border mb-2"><%= entry.category %></span>
            <h4 class="mb-0 fw-bold"><%= entry.billRefNo %></h4>
          </div>
          <div class="text-end">
            <h3 class="mb-0 text-danger fw-bold">&#8377;<%= Number(entry.amount).toLocaleString('en-IN') %></h3>
            <small class="text-muted"><%= moment(entry.date).format('DD MMMM YYYY') %></small>
          </div>
        </div>
      </div>
      <div class="card-body">
        <div class="row mb-4">
          <div class="col-md-6">
            <h6 class="text-muted mb-2">Vendor</h6>
            <p class="fw-semibold"><%= entry.vendor %></p>
          </div>
          <div class="col-md-6">
            <h6 class="text-muted mb-2">Payment Mode</h6>
            <p class="fw-semibold"><%= entry.paymentMode %></p>
          </div>
        </div>

        <div class="mb-4">
          <h6 class="text-muted mb-2">Description</h6>
          <p class="bg-light p-3 rounded"><%= entry.description %></p>
        </div>

        <% if (entry.notes) { %>
          <div class="mb-4">
            <h6 class="text-muted mb-2">Notes</h6>
            <p class="bg-light p-3 rounded"><%= entry.notes %></p>
          </div>
        <% } %>

        <div class="mb-4">
          <h6 class="text-muted mb-2">Recorded By</h6>
          <p class="fw-semibold"><%= entry.author.firstName %> <%= entry.author.lastName %> (<%= entry.author.email %>)</p>
        </div>

        <% if (entry.receiptUrl) { %>
          <div class="mb-4">
            <h6 class="text-muted mb-2">Receipt</h6>
            <a href="<%= entry.receiptUrl %>" target="_blank" class="btn btn-success">
              <i class="bi bi-file-earmark-text me-2"></i>View Receipt
            </a>
          </div>
        <% } %>

        <div class="text-muted small">
          <p class="mb-0">Created: <%= moment(entry.createdAt).format('DD MMM YYYY, h:mm A') %></p>
          <% if (entry.updatedAt) { %>
            <p class="mb-0">Last Updated: <%= moment(entry.updatedAt).format('DD MMM YYYY, h:mm A') %></p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
